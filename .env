# ── 实盘配置（东方财富证券）──────────────────────────────────
# 东方财富证券 PC 客户端基于同花顺下单端，使用 universal_client
BROKER_TYPE=universal_client

# 资金账号（东方财富证券登录账号）
BROKER_ACCOUNT=

# 交易密码
BROKER_PASSWORD=

# 东方财富证券下单程序 xiadan.exe 路径
# 常见路径示例（根据实际安装位置修改）：
#   C:\东方财富证券\交易终端\xiadan.exe
#   C:\东方财富证券\下单\xiadan.exe
#   C:\Users\用户名\AppData\Local\eastmoney\xiadan.exe
BROKER_EXE=D:\stock\east\maintrade.exe

# 通讯密码（部分账户需要，没有则留空）
BROKER_COMM_PASSWORD=

# ── 桥接服务端口（32位Python桥接服务，默认8890）──────────────
BRIDGE_PORT=8890

